http:
  middlewares:
    default-security-headers:
      headers:
        frameDeny: true
        browserXssFilter: true
        contentTypeNosniff: true
        referrerPolicy: "strict-origin-when-cross-origin"
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
    local-auth:
      basicAuth:
        users: {{ traefik_basic_auth_users | to_json }}
